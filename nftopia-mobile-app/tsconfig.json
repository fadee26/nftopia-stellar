{
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/components/*": ["components/*"],
      "@/screens/*": ["screens/*"],
      "@/navigation/*": ["navigation/*"],
      "@/stores/*": ["stores/*"],
      "@/types/*": ["types/*"],
      "@/lib/*": ["lib/*"],
      "@/services/*": ["src/services/*"]
    },
    "jsx": "react-native",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["es2017"],
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true
  }
}
